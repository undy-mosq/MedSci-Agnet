; 复制本文件为 config.ini 后填写。相对路径均相对于 backend 目录（与 config.ini 同级）。

[app]
; NCBI E-utilities（可选，提高速率上限）
; https://www.ncbi.nlm.nih.gov/account/settings/
ncbi_api_key =

; 留空则使用 ../data/journal_metrics.json（相对 backend）
journal_metrics_path =

; MedSci 补全缓存（相对 backend）；留空则 ../data/new_metrics.json
new_journal_metrics_path =

; MedSci 补全：单次 sync 最多刊数、刊间间隔（秒）、是否启用
medsci_batch_size = 10
medsci_min_interval_seconds = 1.0
medsci_enabled = true
; 无 sync/poll 超过该秒数则后台自动取消补全（默认 30）
medsci_client_idle_seconds = 30

; OpenAI 兼容接口
llm_api_base = https://api.openai.com/v1
llm_api_key =
llm_model = gpt-4o-mini

http_timeout_seconds = 60
max_analyze_results = 500
pubmed_retry_sleep_seconds = 1.0
